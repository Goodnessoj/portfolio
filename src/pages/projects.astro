---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import { projects } from '../data/projects';

const featuredProjects = projects.filter(p => p.featured);
const otherProjects = projects.filter(p => !p.featured);
---

<Layout 
  title="Projects | Goodness Ojonuba - Cloud & DevOps Engineer"
  description="Explore Goodness Ojonuba's DevOps and Cloud Engineering projects on GitHub."
>
  <Navbar />
  <main class="pt-24 pb-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-4">
          My <span class="text-orange-500">Projects</span>
        </h1>
        <p class="text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
          A curated selection of infrastructure-as-code projects, CI/CD pipelines, and cloud deployments.
        </p>
      </div>
      
      <!-- Featured Projects -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8 flex items-center gap-2">
          Featured Projects
        </h2>
        <div class="grid lg:grid-cols-3 gap-8">
          {featuredProjects.map((project) => (
            <div class="group bg-white dark:bg-slate-900 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:border-orange-500/50 dark:hover:border-orange-500/30 transition-all duration-300 hover:shadow-xl hover:shadow-orange-500/5 flex flex-col">
              <div class="p-6 flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-3">
                  <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                  <h3 class="text-lg font-bold text-slate-900 dark:text-white group-hover:text-orange-500 transition-colors">{project.name}</h3>
                </div>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4 flex-1">{project.description}</p>
                {project.relatedRepositories && (
                  <div class="mb-4 rounded-lg border border-slate-200 bg-slate-50 p-3 dark:border-slate-700 dark:bg-slate-800/60">
                    <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Connected repositories</p>
                    <div class="flex flex-wrap gap-x-4 gap-y-2">
                      {project.relatedRepositories.map((repository) => (
                        <a href={repository.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs font-medium text-orange-500 transition-colors hover:text-orange-600 hover:underline">
                          {repository.name}
                          <svg class="h-3 w-3" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4m-2-10h6m0 0v6m0-6L10 14" /></svg>
                        </a>
                      ))}
                    </div>
                  </div>
                )}
                <div class="flex flex-wrap gap-2 mb-4">
                  {project.tech.map((t) => (
                    <span class="px-2.5 py-1 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs font-medium">{t}</span>
                  ))}
                </div>
                <div class="flex flex-wrap items-center justify-end gap-3 pt-4 border-t border-slate-200 dark:border-slate-700">
                  <div class="flex items-center gap-3">
                    {!project.relatedRepositories && (
                      <a href={project.url} target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-slate-900 dark:hover:text-white font-medium text-sm transition-colors">Code</a>
                    )}
                    {project.caseStudySlug && (
                      <a href={`/projects/${project.caseStudySlug}`} class="text-orange-500 hover:text-orange-600 font-semibold text-sm inline-flex items-center gap-1 transition-colors">
                        Read case study
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Other Projects -->
      <div>
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8 flex items-center gap-2">
          <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          More Projects
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          {otherProjects.map((project) => (
            <div class="group bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-700 hover:border-orange-500/50 dark:hover:border-orange-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-orange-500/5">
              <div class="flex items-start mb-3">
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                  <h3 class="text-base font-bold text-slate-900 dark:text-white group-hover:text-orange-500 transition-colors">{project.name}</h3>
                </div>
              </div>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4">{project.description}</p>
              <div class="flex items-center justify-between">
                <div class="flex flex-wrap gap-2">
                  {project.tech.map((t) => (
                    <span class="px-2 py-0.5 rounded bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs">{t}</span>
                  ))}
                </div>
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="text-orange-500 hover:text-orange-600 text-sm font-medium inline-flex items-center gap-1 transition-colors">
                  Code
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              </div>
              {project.connectedTo && (
                <div class="mt-3 pt-3 border-t border-slate-200 dark:border-slate-700">
                  <p class="text-xs text-slate-500 dark:text-slate-400">
                    Connected to: <a href={`https://github.com/Goodnessoj/${project.connectedTo}`} target="_blank" rel="noopener noreferrer" class="text-orange-500 hover:text-orange-600 hover:underline">{project.connectedTo}</a>
                  </p>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
      
      <div class="text-center mt-16">
        <a href="https://github.com/Goodnessoj" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-semibold rounded-lg hover:opacity-90 transition-opacity">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View All Repos on GitHub
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
