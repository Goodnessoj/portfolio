---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import { rankedArticles } from '../data/projects';

const platformStyles = {
  Hashnode: 'bg-[#2962ff] text-white',
  'Dev.to': 'bg-slate-900 dark:bg-white text-white dark:text-slate-900',
  Medium: 'bg-[#00AB6C] text-white',
};
---

<Layout
  title="Blog | Goodness Ojonuba - Cloud & DevOps Engineer"
  description="Curated articles about DevOps, multi-cloud infrastructure, Terraform, Kubernetes, automation, and platform engineering."
>
  <Navbar />
  <main class="pt-24 pb-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <header class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-orange-500">Curated technical writing</p>
        <h1 class="mt-4 text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white">
          Featured <span class="text-orange-500">Articles</span>
        </h1>
        <p class="mt-5 text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
          Ranked by technical depth, practical value, and relevance to my cloud and DevOps work—not simply by publication date.
        </p>
      </header>

      <section aria-label="Ranked technical articles" class="grid gap-6 md:grid-cols-2">
        {rankedArticles.map((article, index) => (
          <a href={article.url} target="_blank" rel="noopener noreferrer" class="group relative block rounded-xl border border-slate-200 bg-white p-6 transition-all duration-300 hover:border-orange-500/50 hover:shadow-lg hover:shadow-orange-500/5 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-orange-500/30">
            <div class="mb-4 flex flex-wrap items-center gap-2">
              <span class={`inline-flex items-center rounded px-2.5 py-0.5 text-xs font-semibold ${platformStyles[article.platform]}`}>
                {article.platform}
              </span>
              {index < 3 && (
                <span class="rounded bg-orange-100 px-2.5 py-0.5 text-xs font-semibold text-orange-700 dark:bg-orange-950/40 dark:text-orange-300">
                  Featured #{index + 1}
                </span>
              )}
              <span class="ml-auto text-xs text-slate-400 dark:text-slate-500">{article.date} · {article.readTime}</span>
            </div>

            <h2 class="text-xl font-bold leading-snug text-slate-900 transition-colors group-hover:text-orange-500 dark:text-white">
              {article.title}
            </h2>
            <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
              {article.excerpt}
            </p>

            <div class="mt-5 flex flex-wrap gap-2">
              {article.tags.map((tag) => (
                <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-400">#{tag}</span>
              ))}
            </div>

            <div class="mt-5 flex items-center gap-1 text-sm font-medium text-orange-500">
              Read Article
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </a>
        ))}
      </section>

      <div class="mt-16 flex flex-wrap justify-center gap-4">
        <a href="https://goodnessoj.hashnode.dev" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-[#2962ff] px-6 py-3 font-semibold text-white transition-colors hover:bg-[#1f4ed8]">
          Hashnode
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="https://dev.to/goodnessoj" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-slate-900 px-6 py-3 font-semibold text-white transition-opacity hover:opacity-90 dark:bg-white dark:text-slate-900">
          Dev.to
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="https://medium.com/@goodnessojonuba" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-[#00AB6C] px-6 py-3 font-semibold text-white transition-colors hover:bg-[#009e62]">
          Medium
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
