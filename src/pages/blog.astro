---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import { devtoArticles, mediumArticles } from '../data/projects';
---

<Layout 
  title="Blog | Goodness Ojonuba - Cloud & DevOps Engineer"
  description="Articles about DevOps, cloud infrastructure, Terraform, Kubernetes, and more."
>
  <Navbar />
  <main class="pt-24 pb-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-4">
          My <span class="text-orange-500">Blog</span>
        </h1>
        <p class="text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
          Sharing what I learn about DevOps, cloud infrastructure, and the tools that make it all work.
        </p>
      </div>
      
      <!-- Dev.to Articles -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-slate-900 dark:bg-white text-white dark:text-slate-900 text-sm font-bold">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6v5.32h.57c.38 0 .66-.06.84-.19.18-.12.27-.36.27-.72v-3.5c0-.36-.09-.6-.26-.68zm13.81-2.87c-.54-.55-1.25-.83-2.11-.83H8.7c-.86 0-1.57.28-2.11.83-.54.55-.81 1.24-.81 2.07v5.06c0 .83.27 1.52.81 2.07.54.55 1.25.83 2.11.83h10.42c.86 0 1.57-.28 2.11-.83.54-.55.81-1.24.81-2.07V9.25c0-.83-.27-1.52-.81-2.07zM13.1 14.2h-1.72V9.8H13v4.4zm5.3 0h-1.72V11h-1.2v3.2h-1.72V9.8h4.64v4.4z"/></svg>
            Dev.to
          </span>
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Dev.to Articles</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {devtoArticles.map((article) => (
            <a href={article.url} target="_blank" rel="noopener noreferrer" class="group block bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800 hover:border-orange-500/50 dark:hover:border-orange-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-orange-500/5">
              <div class="flex items-center gap-2 mb-3 text-xs text-slate-400 dark:text-slate-500">
                <span>{article.date}</span>
                <span>·</span>
                <span>{article.readTime}</span>
              </div>
              <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2 group-hover:text-orange-500 transition-colors line-clamp-2">
                {article.title}
              </h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4 line-clamp-2">
                {article.excerpt}
              </p>
              <div class="flex flex-wrap gap-2">
                {article.tags.map((tag) => (
                  <span class="px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs">#{tag}</span>
                ))}
              </div>
              <div class="mt-4 flex items-center gap-1 text-orange-500 text-sm font-medium">
                Read Article
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
      
      <!-- Medium Articles -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[#00AB6C] text-white text-sm font-bold">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zm7.54 3.1c0-1.22-1.57-2.22-3.5-2.22s-3.5 1-3.5 2.22c0 1.22 1.57 2.22 3.5 2.22s3.5-1 3.5-2.22zm5.46 2.2c0-1.1-1.12-2-2.5-2s-2.5.9-2.5 2c0 1.1 1.12 2 2.5 2s2.5-.9 2.5-2z"/></svg>
            Medium
          </span>
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Medium Articles</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {mediumArticles.map((article) => (
            <a href={article.url} target="_blank" rel="noopener noreferrer" class="group block bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800 hover:border-orange-500/50 dark:hover:border-orange-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-orange-500/5">
              <div class="flex items-center gap-2 mb-3 text-xs text-slate-400 dark:text-slate-500">
                <span>{article.date}</span>
                <span>·</span>
                <span>{article.readTime}</span>
              </div>
              <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2 group-hover:text-orange-500 transition-colors line-clamp-2">
                {article.title}
              </h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4 line-clamp-2">
                {article.excerpt}
              </p>
              <div class="flex flex-wrap gap-2">
                {article.tags.map((tag) => (
                  <span class="px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs">#{tag}</span>
                ))}
              </div>
              <div class="mt-4 flex items-center gap-1 text-orange-500 text-sm font-medium">
                Read Article
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
      
      <div class="text-center mt-16">
        <div class="flex justify-center gap-4 flex-wrap">
          <a href="https://dev.to/goodnessoj" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-semibold rounded-lg hover:opacity-90 transition-opacity">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6v5.32h.57c.38 0 .66-.06.84-.19.18-.12.27-.36.27-.72v-3.5c0-.36-.09-.6-.26-.68zm13.81-2.87c-.54-.55-1.25-.83-2.11-.83H8.7c-.86 0-1.57.28-2.11.83-.54.55-.81 1.24-.81 2.07v5.06c0 .83.27 1.52.81 2.07.54.55 1.25.83 2.11.83h10.42c.86 0 1.57-.28 2.11-.83.54-.55.81-1.24.81-2.07V9.25c0-.83-.27-1.52-.81-2.07zM13.1 14.2h-1.72V9.8H13v4.4zm5.3 0h-1.72V11h-1.2v3.2h-1.72V9.8h4.64v4.4z"/></svg>
            All Dev.to Articles
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="https://medium.com/@goodnessojonuba" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-[#00AB6C] text-white font-semibold rounded-lg hover:bg-[#009e62] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zm7.54 3.1c0-1.22-1.57-2.22-3.5-2.22s-3.5 1-3.5 2.22c0 1.22 1.57 2.22 3.5 2.22s3.5-1 3.5-2.22zm5.46 2.2c0-1.1-1.12-2-2.5-2s-2.5.9-2.5 2c0 1.1 1.12 2 2.5 2s2.5-.9 2.5-2z"/></svg>
            All Medium Articles
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
