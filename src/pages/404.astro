---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
---

<Layout 
  title="404 | Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <Navbar />
  <main class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 min-h-[60vh] flex items-center">
    <div class="max-w-xl mx-auto text-center">
      <div class="text-9xl font-bold text-slate-200 dark:text-slate-800 mb-4">404</div>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Page Not Found</h1>
      <p class="text-slate-500 dark:text-slate-400 mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Back to Home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
