---
import { skills } from '../../data/projects';

const categories = [...new Set(skills.map(s => s.category))];
const skillsByCategory = categories.map(cat => ({
  category: cat,
  items: skills.filter(s => s.category === cat),
}));
---

<section id="skills" class="py-20 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-slate-950 transition-colors duration-300">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-4">
        Tech <span class="text-orange-500">Stack</span>
      </h2>
      <p class="text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
        Tools and technologies I use daily to build, deploy, and manage cloud infrastructure.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {skillsByCategory.map(({ category, items }) => (
        <div class="bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800 hover:border-orange-500/50 dark:hover:border-orange-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-orange-500/5">
          <h3 class="text-sm font-semibold text-orange-500 uppercase tracking-wider mb-4">{category}</h3>
          <div class="flex flex-wrap gap-2">
            {items.map((skill) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm font-medium border border-slate-200 dark:border-slate-700 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:border-orange-200 dark:hover:border-orange-800 transition-colors">
                {skill.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
