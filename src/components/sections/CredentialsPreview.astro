---
import { certifications } from '../../data/certifications';

const featuredCertifications = certifications.slice(0, 2);
---

<section id="credentials" class="py-20 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-slate-950 transition-colors duration-300">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-orange-500">Credentials</p>
        <h2 class="mt-4 text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">
          Certified cloud foundations, backed by <span class="text-orange-500">hands-on delivery</span>
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-slate-600 dark:text-slate-300">
          Certified in cloud architecture and strengthened through applied DevOps programs, labs, and real infrastructure projects.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/certifications"
            class="inline-flex items-center gap-2 rounded-lg bg-orange-500 px-5 py-3 font-semibold text-white transition-colors hover:bg-orange-600"
          >
            View all certifications
            <svg class="h-4 w-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        {featuredCertifications.map((certification) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-orange-100 text-orange-600 dark:bg-orange-950/40 dark:text-orange-300">
              <svg class="h-6 w-6" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <div class="mt-5 flex flex-wrap gap-2">
              <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-300">
                Verified
              </span>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                {certification.level}
              </span>
            </div>
            <h3 class="mt-4 text-lg font-bold leading-tight text-slate-900 dark:text-white">{certification.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
              {certification.capabilities.slice(0, 3).join(' • ')}
            </p>
            <a
              href={certification.credentialUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-orange-500 transition-colors hover:text-orange-600"
            >
              Verify on Credly
              <svg class="h-3.5 w-3.5" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4m-2-10h6m0 0v6m0-6L10 14" /></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
