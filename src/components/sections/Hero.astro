---
import { GitStats } from '../../data/projects';
---

<section class="relative min-h-screen flex items-center pt-16 pb-20 px-4 sm:px-6 lg:px-8 overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-20 left-10 w-72 h-72 bg-orange-500/10 dark:bg-orange-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-blue-500/10 dark:bg-blue-500/5 rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-7xl mx-auto w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div class="order-1 space-y-8">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-orange-100 dark:bg-orange-950/30 text-orange-700 dark:text-orange-300 text-sm font-medium">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
          </span>
          Open to Remote Collaborations
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
          <span class="text-slate-900 dark:text-white">Goodness</span>
          <span class="text-orange-500">.</span>
          <br />
          <span class="text-slate-900 dark:text-white">Ojonuba</span>
        </h1>
        
        <p class="text-xl sm:text-2xl font-semibold text-slate-600 dark:text-slate-300">
          Cloud & DevOps Engineer <span class="text-orange-500">|</span> AWS Solutions Architect Associate
        </p>
        
        <p class="text-lg text-slate-500 dark:text-slate-400 max-w-xl leading-relaxed">
          I design, build, and automate scalable cloud infrastructure. From Terraform modules to CI/CD pipelines, 
          I turn complex infrastructure into reliable, repeatable code.
        </p>
        
        <div class="flex flex-wrap gap-4">
          <a 
            href="/projects" 
            class="inline-flex items-center gap-2 px-6 py-3 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-lg transition-colors"
          >
            View Projects
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a 
            href="/blog" 
            class="inline-flex items-center gap-2 px-6 py-3 bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 text-slate-900 dark:text-white font-semibold rounded-lg transition-colors"
          >
            Read My Blog
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </a>
          <a 
            href="/contact" 
            class="inline-flex items-center gap-2 px-6 py-3 border-2 border-slate-300 dark:border-slate-700 hover:border-orange-500 hover:text-orange-500 text-slate-600 dark:text-slate-300 font-semibold rounded-lg transition-colors"
          >
            Contact Me
          </a>
        </div>
        
        <!-- Social Links -->
        <div class="flex items-center gap-4 pt-4">
          <a href="https://github.com/Goodnessoj" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors" aria-label="GitHub">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/sy-goodness/" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#0A66C2] transition-colors" aria-label="LinkedIn">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://twitter.com/synotrixx" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#1DA1F2] transition-colors" aria-label="Twitter/X">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://dev.to/goodnessoj" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#0A0A0A] dark:hover:text-white transition-colors" aria-label="Dev.to">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6v5.32h.57c.38 0 .66-.06.84-.19.18-.12.27-.36.27-.72v-3.5c0-.36-.09-.6-.26-.68zm13.81-2.87c-.54-.55-1.25-.83-2.11-.83H8.7c-.86 0-1.57.28-2.11.83-.54.55-.81 1.24-.81 2.07v5.06c0 .83.27 1.52.81 2.07.54.55 1.25.83 2.11.83h10.42c.86 0 1.57-.28 2.11-.83.54-.55.81-1.24.81-2.07V9.25c0-.83-.27-1.52-.81-2.07zM13.1 14.2h-1.72V9.8H13v4.4zm5.3 0h-1.72V11h-1.2v3.2h-1.72V9.8h4.64v4.4z"/></svg>
          </a>
          <a href="https://medium.com/@goodnessojonuba" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#00AB6C] transition-colors" aria-label="Medium">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zm7.54 3.1c0-1.22-1.57-2.22-3.5-2.22s-3.5 1-3.5 2.22c0 1.22 1.57 2.22 3.5 2.22s3.5-1 3.5-2.22zm5.46 2.2c0-1.1-1.12-2-2.5-2s-2.5.9-2.5 2c0 1.1 1.12 2 2.5 2s2.5-.9 2.5-2z"/></svg>
          </a>
        </div>
        
        <!-- GitHub Stats -->
        <div class="flex items-center gap-6 pt-2 text-sm text-slate-500 dark:text-slate-400">
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            <span>{GitStats.repos} repos</span>
          </div>
          <a href="/certifications" class="flex items-center gap-1.5 transition-colors hover:text-orange-500">
            <svg class="w-4 h-4 text-orange-500" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138z" /></svg>
            <span>2 AWS certifications</span>
          </a>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M5.59 2.07c1.04 0 1.94.66 2.29 1.59l2.07 5.53c.34.9-.1 1.9-.97 2.29l-3.33 1.48a12.32 12.32 0 005.23 5.86l1.48-3.33c.39-.87 1.39-1.31 2.29-.97l5.53 2.07c.93.35 1.59 1.25 1.59 2.29v3.77c0 1.66-1.34 3-3 3h-5.5c-7.73 0-14-6.27-14-14v-5.5c0-1.66 1.34-3 3-3h3.77c1.04 0 1.94.66 2.29 1.59l1.66 4.43z"/></svg>
            <span>Open to hire</span>
          </div>
        </div>
      </div>
      
      <!-- Professional portrait -->
      <div class="order-2">
        <div class="relative mx-auto max-w-md">
          <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-orange-500/30 via-orange-500/5 to-blue-500/20 blur-2xl" aria-hidden="true"></div>
          <div class="relative overflow-hidden rounded-[2rem] border border-white/20 bg-slate-900 shadow-2xl ring-1 ring-slate-900/10 dark:ring-white/10">
            <img
              src="/images/goodness-ojonuba-portrait.webp"
              alt="Professional portrait of Goodness Ojonuba"
              width="900"
              height="1125"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="aspect-[4/5] w-full object-cover object-top"
            />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-slate-950/90 via-slate-950/40 to-transparent px-6 pb-6 pt-20">
              <p class="font-semibold text-white">Goodness Ojonuba</p>
              <p class="text-sm text-slate-300">Cloud & DevOps Engineer</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>
