---
import { projects } from '../../data/projects';

const featuredProjects = projects.filter(p => p.featured);
const gridProjects = projects.filter(p => !p.featured);
---

<section id="projects" class="py-20 px-4 sm:px-6 lg:px-8 bg-white dark:bg-slate-900 transition-colors duration-300">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-4">
        Featured <span class="text-orange-500">Projects</span>
      </h2>
      <p class="text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
        Infrastructure-as-code projects, CI/CD pipelines, and cloud deployments I've built.
      </p>
    </div>
    
    <!-- Featured 3 (Hero Cards) -->
    <div class="grid lg:grid-cols-3 gap-8 mb-12">
      {featuredProjects.map((project, index) => (
        <div class="group bg-slate-50 dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:border-orange-500/50 dark:hover:border-orange-500/30 transition-all duration-300 hover:shadow-xl hover:shadow-orange-500/5 flex flex-col">
          <div class="p-6 flex-1 flex flex-col">
            <div class="mb-5">
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-orange-500 text-white text-xs font-bold">
                Featured #{index + 1}
              </span>
            </div>

            <div class="flex items-start gap-2 mb-3 min-h-12">
              <svg class="w-5 h-5 mt-0.5 shrink-0 text-orange-500" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 00-2-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
              <h3 class="min-w-0 break-words text-lg font-bold leading-snug text-slate-900 dark:text-white group-hover:text-orange-500 transition-colors">{project.name}</h3>
            </div>
            
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4 flex-1">{project.description}</p>

            {project.relatedRepositories && (
              <div class="mb-4 rounded-lg border border-slate-200 bg-white/60 p-3 dark:border-slate-700 dark:bg-slate-900/40">
                <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Connected repositories</p>
                <div class="flex flex-wrap gap-x-4 gap-y-2">
                  {project.relatedRepositories.map((repository) => (
                    <a href={repository.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs font-medium text-orange-500 transition-colors hover:text-orange-600 hover:underline">
                      {repository.name}
                      <svg class="h-3 w-3" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4m-2-10h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                  ))}
                </div>
              </div>
            )}
            
            <div class="flex flex-wrap gap-2 mb-4">
              {project.tech.map((t) => (
                <span class="px-2.5 py-1 rounded-md bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300 text-xs font-medium">{t}</span>
              ))}
            </div>
            
            <div class="flex flex-wrap items-center justify-end gap-3 pt-4 border-t border-slate-200 dark:border-slate-700">
              <div class="flex items-center gap-3">
                {!project.relatedRepositories && (
                  <a href={project.url} target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-slate-900 dark:hover:text-white font-medium text-sm transition-colors">Code</a>
                )}
                {project.caseStudySlug && (
                  <a href={`/projects/${project.caseStudySlug}`} class="text-orange-500 hover:text-orange-600 font-semibold text-sm inline-flex items-center gap-1 transition-colors">
                    Read case study
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Grid Projects (Remaining 2) -->
    <div class="grid md:grid-cols-2 gap-6">
      {gridProjects.slice(0, 2).map((project) => (
        <div class="group bg-slate-50 dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 hover:border-orange-500/50 dark:hover:border-orange-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-orange-500/5">
          <div class="flex items-start mb-3">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
              <h3 class="text-base font-bold text-slate-900 dark:text-white group-hover:text-orange-500 transition-colors">{project.name}</h3>
            </div>
          </div>
          
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4">{project.description}</p>
          
          <div class="flex items-center justify-between">
            <div class="flex flex-wrap gap-2">
              {project.tech.map((t) => (
                <span class="px-2 py-0.5 rounded bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300 text-xs">{t}</span>
              ))}
            </div>
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="text-orange-500 hover:text-orange-600 text-sm font-medium inline-flex items-center gap-1 transition-colors">
              Code
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
    
    <div class="text-center mt-12">
      <a 
        href="/projects" 
        class="inline-flex items-center gap-2 px-6 py-3 bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 text-slate-900 dark:text-white font-semibold rounded-lg transition-colors"
      >
        View All Projects
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
