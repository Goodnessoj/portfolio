---
import { rankedArticles } from '../../data/projects';

const featuredArticles = rankedArticles.slice(0, 4);

const platformStyles = {
  Hashnode: 'bg-[#2962ff] text-white',
  'Dev.to': 'bg-slate-900 dark:bg-white text-white dark:text-slate-900',
  Medium: 'bg-[#00AB6C] text-white',
};
---

<section id="blog" class="py-20 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-slate-950 transition-colors duration-300">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-4">
        Featured <span class="text-orange-500">Articles</span>
      </h2>
      <p class="text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
        Practical guides and case studies on cloud infrastructure, automation, Kubernetes, and modern DevOps practices.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8">
      {featuredArticles.map((article, index) => (
        <a href={article.url} target="_blank" rel="noopener noreferrer" class="group block bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800 hover:border-orange-500/50 dark:hover:border-orange-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-orange-500/5">
          <div class="flex items-center gap-2 mb-3">
            <span class={`inline-flex items-center gap-1 px-2.5 py-0.5 rounded text-xs font-semibold ${platformStyles[article.platform]}`}>
              {article.platform}
            </span>
            {index < 2 && (
              <span class="rounded bg-orange-100 px-2 py-0.5 text-xs font-semibold text-orange-700 dark:bg-orange-950/40 dark:text-orange-300">Top pick</span>
            )}
            <span class="text-xs text-slate-400 dark:text-slate-500">{article.date}</span>
            <span class="text-xs text-slate-400 dark:text-slate-500">·</span>
            <span class="text-xs text-slate-400 dark:text-slate-500">{article.readTime}</span>
          </div>
          
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2 group-hover:text-orange-500 transition-colors line-clamp-2">
            {article.title}
          </h3>
          
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4 line-clamp-2">
            {article.excerpt}
          </p>
          
          <div class="flex flex-wrap gap-2">
            {article.tags.map((tag) => (
              <span class="px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-xs">#{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
    
    <div class="flex flex-wrap justify-center gap-4 mt-12">
      <a
        href="https://goodnessoj.hashnode.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[#2962ff] text-white font-semibold rounded-lg hover:bg-[#1f4ed8] transition-colors"
      >
        Hashnode Articles
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a 
        href="https://dev.to/goodnessoj" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-semibold rounded-lg hover:opacity-90 transition-opacity"
      >
        Dev.to Articles
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a 
        href="https://medium.com/@goodnessojonuba" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[#00AB6C] text-white font-semibold rounded-lg hover:bg-[#009e62] transition-colors"
      >
        Medium Articles
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
