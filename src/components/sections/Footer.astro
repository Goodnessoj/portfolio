---
import { GitStats } from '../../data/projects';
---

<footer class="bg-slate-900 dark:bg-black border-t border-slate-800 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div class="space-y-4">
        <a href="/" class="text-2xl font-bold text-white">
          GO<span class="text-orange-500">.</span>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed">
          Cloud & DevOps Engineer building reliable, scalable infrastructure across cloud platforms with Terraform, Ansible, and Kubernetes.
        </p>
        <div class="flex items-center gap-4">
          <a href="https://github.com/Goodnessoj" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/sy-goodness/" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://twitter.com/synotrixx" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors" aria-label="Twitter/X">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://dev.to/goodnessoj" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors" aria-label="Dev.to">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6v5.32h.57c.38 0 .66-.06.84-.19.18-.12.27-.36.27-.72v-3.5c0-.36-.09-.6-.26-.68zm13.81-2.87c-.54-.55-1.25-.83-2.11-.83H8.7c-.86 0-1.57.28-2.11.83-.54.55-.81 1.24-.81 2.07v5.06c0 .83.27 1.52.81 2.07.54.55 1.25.83 2.11.83h10.42c.86 0 1.57-.28 2.11-.83.54-.55.81-1.24.81-2.07V9.25c0-.83-.27-1.52-.81-2.07zM13.1 14.2h-1.72V9.8H13v4.4zm5.3 0h-1.72V11h-1.2v3.2h-1.72V9.8h4.64v4.4z"/></svg>
          </a>
          <a href="https://medium.com/@goodnessojonuba" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors" aria-label="Medium">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zm7.54 3.1c0-1.22-1.57-2.22-3.5-2.22s-3.5 1-3.5 2.22c0 1.22 1.57 2.22 3.5 2.22s3.5-1 3.5-2.22zm5.46 2.2c0-1.1-1.12-2-2.5-2s-2.5.9-2.5 2c0 1.1 1.12 2 2.5 2s2.5-.9 2.5-2z"/></svg>
          </a>
        </div>
      </div>
      
      <!-- Links -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Navigation</h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-slate-400 hover:text-orange-500 text-sm transition-colors">Home</a></li>
          <li><a href="/about" class="text-slate-400 hover:text-orange-500 text-sm transition-colors">About</a></li>
          <li><a href="/projects" class="text-slate-400 hover:text-orange-500 text-sm transition-colors">Projects</a></li>
          <li><a href="/certifications" class="text-slate-400 hover:text-orange-500 text-sm transition-colors">Certifications</a></li>
          <li><a href="/blog" class="text-slate-400 hover:text-orange-500 text-sm transition-colors">Blog</a></li>
          <li><a href="/contact" class="text-slate-400 hover:text-orange-500 text-sm transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <!-- Stats -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">GitHub Stats</h4>
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center">
            <div class="text-xl font-bold text-white">{GitStats.repos}</div>
            <div class="text-xs text-slate-500">Repos</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-bold text-white">{GitStats.followers}</div>
            <div class="text-xs text-slate-500">Followers</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-bold text-white">{GitStats.following}</div>
            <div class="text-xs text-slate-500">Following</div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="border-t border-slate-800 pt-8 text-center">
      <p class="text-sm text-slate-500">
        &copy; {new Date().getFullYear()} Goodness Ojonuba. Designed, built, and deployed by me.
      </p>
    </div>
  </div>
</footer>
